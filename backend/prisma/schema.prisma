generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  MANAGER
  WAITER
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  DISABLED
}

enum OrderStatus {
  OPEN
  CLOSED
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  MIXED
}

enum ShiftStatus {
  OPEN
  CLOSED
}

enum InventoryUnit {
  GRAM
  MILLILITER
  PIECE
}

enum StockMovementType {
  INITIAL_IN
  PURCHASE_IN
  SALE_OUT
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
}

enum GuestSessionStatus {
  OPEN
  EXPIRED
  CLOSED
}

enum QrOrderRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELED
}

enum ServiceRequestStatus {
  PENDING
  ACKNOWLEDGED
  COMPLETED
  CANCELED
}

enum ServiceRequestType {
  CALL_WAITER
}

enum OrderItemSource {
  STAFF
  QR_CUSTOMER
}

enum OrderItemFulfillmentStatus {
  ACCEPTED
  PREPARING
  READY
  SERVED
  CANCELED
}

model User {
  id                          String              @id @default(cuid())
  fullName                    String
  phone                       String?             @unique
  passwordHash                String?
  telegramUserId              BigInt?             @unique
  telegramUsername            String?             @unique
  permissions                 String[]            @default([])
  salesSharePercent           Decimal             @default(8.00) @db.Decimal(5, 2)
  role                        UserRole
  isActive                    Boolean             @default(true)
  branchId                    String?
  branch                      Branch?             @relation("BranchStaff", fields: [branchId], references: [id], onDelete: SetNull)
  ownedBranches               Branch[]            @relation("BranchOwner")
  managerBranches             ManagerBranch[]
  orders                      Order[]             @relation("OrderWaiter")
  expenses                    Expense[]           @relation("ExpenseCreator")
  waiterShifts                WaiterShift[]       @relation("ShiftWaiter")
  openedShifts                WaiterShift[]       @relation("ShiftOpenedBy")
  closedShifts                WaiterShift[]       @relation("ShiftClosedBy")
  payouts                     CommissionPayout[]  @relation("CommissionWaiter")
  inventoryPurchases          InventoryPurchase[] @relation("InventoryPurchaseCreator")
  stockMovements              StockMovement[]     @relation("StockMovementCreator")
  acceptedQrOrders            QrOrderRequest[]    @relation("QrOrderAcceptedBy")
  rejectedQrOrders            QrOrderRequest[]    @relation("QrOrderRejectedBy")
  acknowledgedServiceRequests ServiceRequest[]    @relation("ServiceRequestAcknowledgedBy")
  completedServiceRequests    ServiceRequest[]    @relation("ServiceRequestCompletedBy")
  createdAt                   DateTime            @default(now())
  updatedAt                   DateTime            @updatedAt

  @@index([role])
  @@index([branchId, role])
  @@index([isActive])
}

model Branch {
  id                 String              @id @default(cuid())
  name               String              @unique
  address            String?
  shiftEnd           String?
  isActive           Boolean             @default(true)
  ownerId            String
  owner              User                @relation("BranchOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  staff              User[]              @relation("BranchStaff")
  managerAssignments ManagerBranch[]
  tables             Table[]
  categories         Category[]
  products           Product[]
  productRecipes     ProductRecipe[]
  ingredients        Ingredient[]
  inventoryPurchases InventoryPurchase[]
  stockMovements     StockMovement[]
  orders             Order[]
  expenses           Expense[]
  waiterShifts       WaiterShift[]
  payouts            CommissionPayout[]
  expenseCategories  ExpenseCategory[]
  guestSessions      GuestTableSession[]
  qrOrderRequests    QrOrderRequest[]
  serviceRequests    ServiceRequest[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([ownerId])
  @@index([isActive])
}

model ManagerBranch {
  id        String   @id @default(cuid())
  managerId String
  branchId  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  manager   User     @relation(fields: [managerId], references: [id], onDelete: Cascade)
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([managerId, branchId])
  @@index([branchId, isActive])
  @@index([managerId, isActive])
}

model Table {
  id                String              @id @default(cuid())
  branchId          String
  branch            Branch              @relation(fields: [branchId], references: [id], onDelete: Cascade)
  name              String
  seatsCount        Int                 @default(4)
  status            TableStatus         @default(AVAILABLE)
  qrPublicToken     String?             @unique
  qrEnabled         Boolean             @default(true)
  selfOrderEnabled  Boolean             @default(true)
  callWaiterEnabled Boolean             @default(true)
  qrVersion         Int                 @default(1)
  qrLastGeneratedAt DateTime?
  qrLastScannedAt   DateTime?
  orders            Order[]
  guestSessions     GuestTableSession[]
  qrOrderRequests   QrOrderRequest[]
  serviceRequests   ServiceRequest[]
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@unique([branchId, name])
  @@index([branchId, status])
}

model Category {
  id        String    @id @default(cuid())
  branchId  String
  branch    Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  name      String
  sortOrder Int       @default(0)
  isActive  Boolean   @default(true)
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([branchId, name])
  @@index([branchId, sortOrder])
  @@index([branchId, isActive])
}

model Product {
  id           String               @id @default(cuid())
  branchId     String
  categoryId   String
  branch       Branch               @relation(fields: [branchId], references: [id], onDelete: Cascade)
  category     Category             @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  name         String
  sku          String?              @unique
  price        Decimal              @db.Decimal(12, 2)
  cost         Decimal?             @db.Decimal(12, 2)
  portionLabel String?
  imageUrl     String?
  description  String?
  isActive     Boolean              @default(true)
  sortOrder    Int                  @default(0)
  recipe       ProductRecipe?
  orderItems   OrderItem[]
  qrItems      QrOrderRequestItem[]
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@unique([branchId, categoryId, name])
  @@index([branchId, categoryId])
  @@index([categoryId, isActive])
}

model Order {
  id                String           @id @default(cuid())
  branchId          String
  tableId           String?
  waiterId          String?
  shiftId           String?
  orderNumber       Int
  status            OrderStatus      @default(OPEN)
  subtotalAmount    Decimal          @default(0) @db.Decimal(12, 2)
  discountAmount    Decimal          @default(0) @db.Decimal(12, 2)
  totalAmount       Decimal          @default(0) @db.Decimal(12, 2)
  paidAmount        Decimal          @default(0) @db.Decimal(12, 2)
  costAmount        Decimal          @default(0) @db.Decimal(12, 2)
  grossProfitAmount Decimal          @default(0) @db.Decimal(12, 2)
  paymentMethod     PaymentMethod?
  note              String?
  openedAt          DateTime         @default(now())
  closedAt          DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  branch            Branch           @relation(fields: [branchId], references: [id], onDelete: Cascade)
  table             Table?           @relation(fields: [tableId], references: [id], onDelete: SetNull)
  waiter            User?            @relation("OrderWaiter", fields: [waiterId], references: [id], onDelete: SetNull)
  shift             WaiterShift?     @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  items             OrderItem[]
  qrOrderRequests   QrOrderRequest[]

  @@unique([branchId, orderNumber])
  @@index([branchId, status, openedAt])
  @@index([tableId, status])
  @@index([waiterId, openedAt])
  @@index([shiftId])
}

model OrderItem {
  id                String                     @id @default(cuid())
  orderId           String
  productId         String?
  requestId         String?
  guestSessionId    String?
  productName       String
  unitPrice         Decimal                    @db.Decimal(12, 2)
  quantity          Int
  lineTotal         Decimal                    @db.Decimal(12, 2)
  source            OrderItemSource            @default(STAFF)
  fulfillmentStatus OrderItemFulfillmentStatus @default(ACCEPTED)
  note              String?
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
  order             Order                      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product           Product?                   @relation(fields: [productId], references: [id], onDelete: SetNull)
  request           QrOrderRequest?            @relation("QrOrderRequestOrderItems", fields: [requestId], references: [id], onDelete: SetNull)
  guestSession      GuestTableSession?         @relation("GuestSessionOrderItems", fields: [guestSessionId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([productId])
  @@index([requestId])
  @@index([guestSessionId])
  @@index([fulfillmentStatus])
}

model Expense {
  id          String           @id @default(cuid())
  branchId    String
  createdById String?
  categoryId  String?
  title       String
  amount      Decimal          @db.Decimal(12, 2)
  description String?
  spentAt     DateTime         @default(now())
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  branch      Branch           @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdBy   User?            @relation("ExpenseCreator", fields: [createdById], references: [id], onDelete: SetNull)
  category    ExpenseCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([branchId, spentAt])
  @@index([createdById])
  @@index([categoryId])
}

model ExpenseCategory {
  id        String    @id @default(cuid())
  branchId  String
  branch    Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  name      String
  expenses  Expense[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([branchId, name])
  @@index([branchId])
}

model WaiterShift {
  id           String      @id @default(cuid())
  branchId     String
  waiterId     String
  openedById   String?
  closedById   String?
  status       ShiftStatus @default(OPEN)
  openedAt     DateTime    @default(now())
  closedAt     DateTime?
  openingNote  String?
  closingNote  String?
  startingCash Decimal     @default(0) @db.Decimal(12, 2)
  endingCash   Decimal?    @db.Decimal(12, 2)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  branch       Branch      @relation(fields: [branchId], references: [id], onDelete: Cascade)
  waiter       User        @relation("ShiftWaiter", fields: [waiterId], references: [id], onDelete: Cascade)
  openedBy     User?       @relation("ShiftOpenedBy", fields: [openedById], references: [id], onDelete: SetNull)
  closedBy     User?       @relation("ShiftClosedBy", fields: [closedById], references: [id], onDelete: SetNull)
  orders       Order[]

  @@unique([waiterId, openedAt])
  @@index([branchId, status, openedAt])
  @@index([waiterId, status])
  @@index([openedAt])
}

model CommissionPayout {
  id        String   @id @default(cuid())
  branchId  String
  waiterId  String
  amount    Decimal  @db.Decimal(12, 2)
  note      String?
  paidAt    DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  waiter    User     @relation("CommissionWaiter", fields: [waiterId], references: [id], onDelete: Cascade)

  @@index([branchId, paidAt])
  @@index([waiterId])
}

model Ingredient {
  id             String                  @id @default(cuid())
  branchId       String
  name           String
  unit           InventoryUnit
  minQty         Decimal                 @default(0) @db.Decimal(14, 3)
  currentQty     Decimal                 @default(0) @db.Decimal(14, 3)
  avgUnitCost    Decimal                 @default(0) @db.Decimal(14, 4)
  isActive       Boolean                 @default(true)
  branch         Branch                  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  recipeItems    ProductRecipeItem[]
  purchaseItems  InventoryPurchaseItem[]
  stockMovements StockMovement[]
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  @@unique([branchId, name])
  @@index([branchId, isActive])
  @@index([branchId, name])
  @@index([branchId, currentQty])
}

model ProductRecipe {
  id        String              @id @default(cuid())
  branchId  String
  productId String              @unique
  note      String?
  isActive  Boolean             @default(true)
  branch    Branch              @relation(fields: [branchId], references: [id], onDelete: Cascade)
  product   Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  items     ProductRecipeItem[]
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@index([branchId, isActive])
}

model ProductRecipeItem {
  id           String        @id @default(cuid())
  recipeId     String
  ingredientId String
  quantity     Decimal       @db.Decimal(14, 3)
  recipe       ProductRecipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredient   Ingredient    @relation(fields: [ingredientId], references: [id], onDelete: Restrict)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([recipeId, ingredientId])
  @@index([ingredientId])
}

model InventoryPurchase {
  id           String                  @id @default(cuid())
  branchId     String
  createdById  String?
  supplierName String?
  note         String?
  totalAmount  Decimal                 @default(0) @db.Decimal(12, 2)
  purchasedAt  DateTime                @default(now())
  branch       Branch                  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdBy    User?                   @relation("InventoryPurchaseCreator", fields: [createdById], references: [id], onDelete: SetNull)
  items        InventoryPurchaseItem[]
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  @@index([branchId, purchasedAt])
  @@index([createdById])
}

model InventoryPurchaseItem {
  id           String            @id @default(cuid())
  purchaseId   String
  ingredientId String
  quantity     Decimal           @db.Decimal(14, 3)
  unitCost     Decimal           @db.Decimal(14, 4)
  totalCost    Decimal           @db.Decimal(12, 2)
  purchase     InventoryPurchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  ingredient   Ingredient        @relation(fields: [ingredientId], references: [id], onDelete: Restrict)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([purchaseId])
  @@index([ingredientId])
}

model StockMovement {
  id             String            @id @default(cuid())
  branchId       String
  ingredientId   String
  createdById    String?
  type           StockMovementType
  quantityChange Decimal           @db.Decimal(14, 3)
  quantityAfter  Decimal           @db.Decimal(14, 3)
  unitCost       Decimal?          @db.Decimal(14, 4)
  totalCost      Decimal?          @db.Decimal(12, 2)
  referenceType  String?
  referenceId    String?
  note           String?
  branch         Branch            @relation(fields: [branchId], references: [id], onDelete: Cascade)
  ingredient     Ingredient        @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  createdBy      User?             @relation("StockMovementCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt      DateTime          @default(now())

  @@index([branchId, createdAt])
  @@index([ingredientId, createdAt])
  @@index([branchId, type, createdAt])
  @@index([referenceType, referenceId])
}

model GuestTableSession {
  id               String             @id @default(cuid())
  branchId         String
  tableId          String
  publicSessionKey String             @unique
  status           GuestSessionStatus @default(OPEN)
  ipHash           String?
  userAgentHash    String?
  startedAt        DateTime           @default(now())
  lastSeenAt       DateTime           @default(now())
  lastSubmittedAt  DateTime?
  endedAt          DateTime?
  branch           Branch             @relation(fields: [branchId], references: [id], onDelete: Cascade)
  table            Table              @relation(fields: [tableId], references: [id], onDelete: Cascade)
  qrOrderRequests  QrOrderRequest[]
  serviceRequests  ServiceRequest[]
  orderItems       OrderItem[]        @relation("GuestSessionOrderItems")

  @@index([branchId, tableId, status, lastSeenAt])
  @@index([tableId, status, startedAt])
}

model QrOrderRequest {
  id              String               @id @default(cuid())
  publicCode      String               @unique
  clientRequestId String
  branchId        String
  tableId         String
  guestSessionId  String
  linkedOrderId   String?
  status          QrOrderRequestStatus @default(PENDING)
  note            String?
  rejectionReason String?
  subtotalAmount  Decimal              @default(0) @db.Decimal(12, 2)
  acceptedAt      DateTime?
  acceptedById    String?
  rejectedAt      DateTime?
  rejectedById    String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  branch          Branch               @relation(fields: [branchId], references: [id], onDelete: Cascade)
  table           Table                @relation(fields: [tableId], references: [id], onDelete: Cascade)
  guestSession    GuestTableSession    @relation(fields: [guestSessionId], references: [id], onDelete: Cascade)
  linkedOrder     Order?               @relation(fields: [linkedOrderId], references: [id], onDelete: SetNull)
  acceptedBy      User?                @relation("QrOrderAcceptedBy", fields: [acceptedById], references: [id], onDelete: SetNull)
  rejectedBy      User?                @relation("QrOrderRejectedBy", fields: [rejectedById], references: [id], onDelete: SetNull)
  items           QrOrderRequestItem[]
  orderItems      OrderItem[]          @relation("QrOrderRequestOrderItems")

  @@unique([guestSessionId, clientRequestId])
  @@index([branchId, status, createdAt])
  @@index([tableId, status, createdAt])
  @@index([guestSessionId, createdAt])
}

model QrOrderRequestItem {
  id                      String         @id @default(cuid())
  requestId               String
  productId               String?
  productNameSnapshot     String
  productImageUrlSnapshot String?
  portionLabelSnapshot    String?
  unitPriceSnapshot       Decimal        @db.Decimal(12, 2)
  quantity                Int
  note                    String?
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  request                 QrOrderRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  product                 Product?       @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([requestId])
  @@index([productId])
}

model ServiceRequest {
  id               String               @id @default(cuid())
  publicCode       String               @unique
  branchId         String
  tableId          String
  guestSessionId   String
  requestType      ServiceRequestType   @default(CALL_WAITER)
  status           ServiceRequestStatus @default(PENDING)
  note             String?
  acknowledgedAt   DateTime?
  acknowledgedById String?
  completedAt      DateTime?
  completedById    String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  branch           Branch               @relation(fields: [branchId], references: [id], onDelete: Cascade)
  table            Table                @relation(fields: [tableId], references: [id], onDelete: Cascade)
  guestSession     GuestTableSession    @relation(fields: [guestSessionId], references: [id], onDelete: Cascade)
  acknowledgedBy   User?                @relation("ServiceRequestAcknowledgedBy", fields: [acknowledgedById], references: [id], onDelete: SetNull)
  completedBy      User?                @relation("ServiceRequestCompletedBy", fields: [completedById], references: [id], onDelete: SetNull)

  @@index([branchId, status, createdAt])
  @@index([tableId, status, createdAt])
  @@index([guestSessionId, createdAt])
}

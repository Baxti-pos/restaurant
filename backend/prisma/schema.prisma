generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  MANAGER
  WAITER
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  DISABLED
}

enum OrderStatus {
  OPEN
  CLOSED
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  MIXED
}

enum ShiftStatus {
  OPEN
  CLOSED
}

model User {
  id             String        @id @default(cuid())
  fullName       String
  phone          String?       @unique
  passwordHash   String?
  telegramUserId BigInt?       @unique
  telegramUsername String?     @unique
  permissions    String[]      @default([])
  salesSharePercent Decimal    @default(8.00) @db.Decimal(5, 2)
  role           UserRole
  isActive       Boolean       @default(true)
  branchId       String?
  branch         Branch?       @relation("BranchStaff", fields: [branchId], references: [id], onDelete: SetNull)
  ownedBranches  Branch[]      @relation("BranchOwner")
  managerBranches ManagerBranch[]
  orders         Order[]       @relation("OrderWaiter")
  expenses       Expense[]     @relation("ExpenseCreator")
  waiterShifts   WaiterShift[] @relation("ShiftWaiter")
  openedShifts   WaiterShift[] @relation("ShiftOpenedBy")
  closedShifts   WaiterShift[] @relation("ShiftClosedBy")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([role])
  @@index([branchId, role])
  @@index([isActive])
}

model Branch {
  id           String        @id @default(cuid())
  name         String        @unique
  address      String?
  shiftEnd     String?
  isActive     Boolean       @default(true)
  ownerId      String
  owner        User          @relation("BranchOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  staff        User[]        @relation("BranchStaff")
  managerAssignments ManagerBranch[]
  tables       Table[]
  categories   Category[]
  products     Product[]
  orders       Order[]
  expenses     Expense[]
  waiterShifts WaiterShift[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([ownerId])
  @@index([isActive])
}

model ManagerBranch {
  id        String   @id @default(cuid())
  managerId String
  branchId  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  manager   User     @relation(fields: [managerId], references: [id], onDelete: Cascade)
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([managerId, branchId])
  @@index([branchId, isActive])
  @@index([managerId, isActive])
}

model Table {
  id         String      @id @default(cuid())
  branchId   String
  branch     Branch      @relation(fields: [branchId], references: [id], onDelete: Cascade)
  name       String
  seatsCount Int         @default(4)
  status     TableStatus @default(AVAILABLE)
  orders     Order[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@unique([branchId, name])
  @@index([branchId, status])
}

model Category {
  id        String    @id @default(cuid())
  branchId  String
  branch    Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  name      String
  sortOrder Int       @default(0)
  isActive  Boolean   @default(true)
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([branchId, name])
  @@index([branchId, sortOrder])
  @@index([branchId, isActive])
}

model Product {
  id        String      @id @default(cuid())
  branchId  String
  categoryId String
  branch    Branch      @relation(fields: [branchId], references: [id], onDelete: Cascade)
  category  Category    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  name      String
  sku       String?     @unique
  price     Decimal     @db.Decimal(12, 2)
  cost      Decimal?    @db.Decimal(12, 2)
  isActive  Boolean     @default(true)
  sortOrder Int         @default(0)
  orderItems OrderItem[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([branchId, categoryId, name])
  @@index([branchId, categoryId])
  @@index([categoryId, isActive])
}

model Order {
  id             String        @id @default(cuid())
  branchId        String
  tableId         String?
  waiterId        String?
  shiftId         String?
  orderNumber     Int
  status          OrderStatus   @default(OPEN)
  subtotalAmount  Decimal       @default(0) @db.Decimal(12, 2)
  discountAmount  Decimal       @default(0) @db.Decimal(12, 2)
  totalAmount     Decimal       @default(0) @db.Decimal(12, 2)
  paidAmount      Decimal       @default(0) @db.Decimal(12, 2)
  paymentMethod   PaymentMethod?
  note            String?
  openedAt        DateTime      @default(now())
  closedAt        DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  branch          Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  table           Table?        @relation(fields: [tableId], references: [id], onDelete: SetNull)
  waiter          User?         @relation("OrderWaiter", fields: [waiterId], references: [id], onDelete: SetNull)
  shift           WaiterShift?  @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  items           OrderItem[]

  @@unique([branchId, orderNumber])
  @@index([branchId, status, openedAt])
  @@index([tableId, status])
  @@index([waiterId, openedAt])
  @@index([shiftId])
}

model OrderItem {
  id          String    @id @default(cuid())
  orderId      String
  productId    String?
  productName  String
  unitPrice    Decimal   @db.Decimal(12, 2)
  quantity     Int
  lineTotal    Decimal   @db.Decimal(12, 2)
  note         String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  order        Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product      Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([productId])
}

model Expense {
  id          String    @id @default(cuid())
  branchId     String
  createdById  String?
  title        String
  amount       Decimal   @db.Decimal(12, 2)
  description  String?
  spentAt      DateTime  @default(now())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  branch       Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdBy    User?     @relation("ExpenseCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([branchId, spentAt])
  @@index([createdById])
}

model WaiterShift {
  id          String      @id @default(cuid())
  branchId     String
  waiterId     String
  openedById   String?
  closedById   String?
  status       ShiftStatus @default(OPEN)
  openedAt     DateTime    @default(now())
  closedAt     DateTime?
  openingNote  String?
  closingNote  String?
  startingCash Decimal     @default(0) @db.Decimal(12, 2)
  endingCash   Decimal?    @db.Decimal(12, 2)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  branch       Branch      @relation(fields: [branchId], references: [id], onDelete: Cascade)
  waiter       User        @relation("ShiftWaiter", fields: [waiterId], references: [id], onDelete: Cascade)
  openedBy     User?       @relation("ShiftOpenedBy", fields: [openedById], references: [id], onDelete: SetNull)
  closedBy     User?       @relation("ShiftClosedBy", fields: [closedById], references: [id], onDelete: SetNull)
  orders       Order[]

  @@unique([waiterId, openedAt])
  @@index([branchId, status, openedAt])
  @@index([waiterId, status])
  @@index([openedAt])
}
